{
  "expo": {
    "name": "GeoNode",
    "slug": "gapps",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "gapps",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.radenrdns.geonode"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0f172a"
      },
      "package": "com.radenrdns.geonode",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyAvnHxmMs5Z2nLx-JIZeNRzD4WOc3oLJ8M"
        }
      }
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#6366f1",
          "sounds": [],
          "androidMode": "default"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Izinkan GeoNode mengakses lokasi untuk menampilkan posisimu di peta.",
          "locationAlwaysPermission": "Izinkan GeoNode mengakses lokasi di latar belakang.",
          "locationWhenInUsePermission": "Izinkan GeoNode mengakses lokasi saat aplikasi digunakan."
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
"extra": {
  "router": {
    "origin": "https://gapps-production.up.railway.app"
  },
  "eas": {
    "projectId": "5ec94f92-9e29-4462-bf06-bb5fa64a4988"
  }
}
  }
}
